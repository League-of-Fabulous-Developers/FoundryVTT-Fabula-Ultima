<section class="tab character {{tab.cssClass}} pfu-profile__character" data-tab="character" data-group="primary">

	{{#with character}}
		<div class="left">
			<!-- Header -->
			<div class="header">
				<div class="flexrow flex-between">
					<div class="name">{{this.name}}</div>
					<div class="level-row">
						<span class="lv-badge">{{this.actor.system.level.value}}</span>
					</div>
				</div>
				<div class="flexrow flex-between">
					{{#if this.actor.system.resources.identity.name}}
						<span class="identity">{{this.actor.system.resources.identity.name}}</span>
					{{/if}}
					{{#if this.actor.system.resources.origin.name}}
						<span class="origin">{{this.actor.system.resources.origin.name}}</span>
					{{/if}}
				</div>
			</div>

			<!-- Classes -->
			<div class="classes">
				{{#each this.classes}}
					<div class="entry">
						<img src="{{this.img}}" data-tooltip="{{this.name}}" />
						<span>{{this.name}}</span>
					</div>
				{{/each}}
			</div>

			<!-- Attributes -->
			<div class="section">
				<div class="flexrow flex-group-center">
					{{#each this.attributes}}
						{{pfuIconAttribute @key value=this}}
					{{/each}}
				</div>
			</div>

			<!-- Resources -->
			<div class="section flex-group-center">
				<div class="bars">
					{{#each this.resources}}
						<div class="bar {{this.name}}">
							<i class="fu-icon--s {{pfuIconClass this.name}}"
							   data-tooltip="{{this.label}}"></i>
							<div class="track">
								<div class="fill" style="--fill-width: {{this.percentage}}%;"></div>
							</div>
							<span class="hp-text">{{this.current}}</span>
							<span class="max">/{{this.max}}</span>
						</div>
					{{/each}}
				</div>
			</div>

			<!-- Equipment -->
			{{#if this.equipment}}
				<div class="panel-label">Equipment</div>
				<div class="panel">
					<div class="items">
						{{#each this.equipment}}
							<div class="entry">
								<div class="fu-icon__container">
									<img class="fu-icon--m" src="{{this.img}}" data-tooltip="{{this.name}}" />
								</div>
								<span>{{this.name}}</span>
							</div>
						{{/each}}
					</div>
				</div>
			{{/if}}

			<!-- Skills -->
			{{#if this.skills}}
				<div class="panel-label">Skills</div>
				<div class="panel" style="overflow-y: auto">
					<div class="items">
						{{#each this.skills}}
							<div class="entry">
								<div class="fu-icon__container">
									<img class="fu-icon--m" src="{{this.img}}" data-tooltip="{{this.name}}" />
								</div>
								<span>{{this.name}}</span>
							</div>
						{{/each}}
					</div>
				</div>
			{{/if}}

		</div>

		<div class="right">
			<!-- Portrait -->
			<a class="portrait {{role}}" data-action="revealActor"
			   data-actor="{{this.actor.uuid}}"
			   data-type="character">
				<img class="portrait {{role}}"
					 src="{{this.actor.img}}"
					 data-tooltip="{{this.name}}" />
			</a>
			<div class="portrait-fade"></div>
		</div>
	{{/with}}
</section>