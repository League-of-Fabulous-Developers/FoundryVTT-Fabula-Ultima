<fieldset>
	<div class="form-group">
		<label>{{localize "Name"}}</label>
		<div class="form-fields">
			<input type="text" name="name" value="{{entry.name}}" />
		</div>
	</div>

	<div class="form-group">
		<label>{{localize "Image"}}</label>
		<div class="form-fields">
			<img class="profile-img flexcol" src="{{lookup entry 'img'}}"
				 data-action="editImage"
				 data-edit="{{pfuConcat 'system.codex.' ../category '.' @index '.img'}}" title="{{entry.name}}" alt=""/>

			<input type="text" name="img" value="{{entry.img}}" />
			<button type="button" data-action="browse">
				<i class="fas fa-file-image"></i>
			</button>
		</div>
	</div>

	<div class="form-group">
		<label>{{localize "Description"}}</label>
		<div class="form-fields">
			<prose-mirror name="description"
						  compact="true"
						  value="{{entry.description}}">
			</prose-mirror>
		</div>
	</div>
</fieldset>