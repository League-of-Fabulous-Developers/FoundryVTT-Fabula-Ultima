<div class="character-list">
	{{#each characters}}
		<div class="entry">
			<div class="header">
				<div class="portrait-badge">
					<a data-action="revealActor" data-actor="{{this.actor.uuid}}" data-type="character">
						<img src="{{this.actor.img}}" alt="{{this.name}}"/>
					</a>
				</div>
				<div class="name">{{ this.name }}</div>
			</div>
			<div class="bars">
				{{#each this.resources}}
					<div class="bar {{this.name}}">
						<div class="track">
							<div class="fill" style="width: {{this.percentage}}%;"></div>
						</div>
						<span class="text">
						{{this.current}}<span class="max">/{{this.max}}</span>
					</span>
					</div>
				{{/each}}
			</div>
		</div>
	{{/each}}
</div>

<div class="character-wheel">
	<div class="wheel-orbit">
		{{#each characters}}
			<div class="wheel-portrait character-option {{#if @first}}active{{/if}}"
				 data-uuid="{{this.actor.uuid}}" data-type="character"
				 style="--index: {{@index}}; --total: {{../characters.length}};">
				<a data-action="inspectCharacter"
				   data-actor="{{this.actor.uuid}}"
				   data-type="character">
					{{pfuImage this.actor.prototypeToken.texture.src 'portrait' this.name}}
				</a>
			</div>
		{{/each}}
		{{#each companions}}
			<div class="wheel-portrait character-option {{#if @first}}active{{/if}}"
				 data-uuid="{{this.actor.uuid}}" data-type="companion"
				 style="--index: {{@index}}; --total: {{../characters.length}};">
				<a data-action="revealActor"
				   data-actor="{{this.actor.uuid}}"
				   data-type="companion">
					{{pfuImage this.actor.prototypeToken.texture.src 'portrait' this.name}}
				</a>
			</div>
		{{/each}}
	</div>
</div>