{{#each characters}}
{{!-- Character Card  --}}
	<div class="section-container plate character character-option {{this.statusClass}}"
		 data-uuid="{{this.actor.uuid}}" data-type="character">

		<div class="image-container">
			<a data-action="revealActor" data-actor="{{this.actor.uuid}}" data-type="character">
				<img class="portrait {{role}}" src="{{ this.actor.img }}"
					 data-tooltip="{{ this.name }}" />
			</a>
			<div class="classes">
				{{#each this.classes}}
					<img class="item" src="{{ this.img }}" data-tooltip="{{ this.name }}" />
				{{/each}}
			</div>
		</div>

		<div class="name">{{ this.name }}</div>
		<div class="identity">{{this.identity }}</div>

		<div class="bars">
			{{#each this.resources}}
				<div class="bar {{this.name}}">
					<i class="fu-icon--s {{pfuIconClass this.name}}" data-tooltip="{{this.label}}" style="width: 18px;"></i>
					<div class="track">
						<div class="fill" style="width: {{this.percentage}}%;"></div>
					</div>
					<span>{{this.current}}/{{this.max}}</span>
				</div>
			{{/each}}
		</div>

		<div class="resources">
			<i class="fu-icon--s {{pfuIconClass 'zenit'}}" data-tooltip="{{localize @root.currency}}"></i>
			{{this.zenit}}

			<i class="fu-icon--s {{pfuIconClass 'fp'}}" data-tooltip="{{localize 'FU.FabulaPoints'}}"></i>
			{{this.fp}}
		</div>


	</div>
{{/each}}

{{#each companions}}
{{!-- Companion Card --}}
	<div class="section-container plate companion character-option" data-uuid="{{this.actor.uuid}}"
		 data-type="companion">

		<a data-action="revealActor" data-actor="{{this.actor.uuid}}" data-type="companion">
			<img class="portrait damage" src="{{ this.actor.img }}" data-tooltip="{{ this.name }}" />
		</a>

		<div class="name">{{ this.name }}</div>
		<div class="identity"><span>{{{this.identity }}}</span></div>

		{{#each this.resources}}
			<div class="bar {{this.name}}">
				<i class="icon {{this.icon}}" data-tooltip="{{this.label}}" style="width: 18px;"></i>
				<div class="track">
					<div class="fill" style="width: {{this.percentage}}%;"></div>
				</div>
				<span class="label">{{this.current}}/{{this.max}}</span>
			</div>
		{{/each}}
	</div>
{{/each}}