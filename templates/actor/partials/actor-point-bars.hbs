<!-- HP -->
<div class="resource-container resource-content" data-tooltip="{{localize 'FU.HealthPoints'}}<br>Current: {{
system.resources.hp.value
}}<br>Crisis: {{system.resources.hp.crisisScore}}
                <br>Bonus: {{ system.resources.hp.bonus }} <br>Max: {{
system.resources.hp.max
}}" aria-describedby="tooltip">

	<div class="resource-label-wrapper">
		<label class="fu-icon__container resource-label-l" data-tooltip="{{localize 'FU.HealthPoints'}}"
			   aria-describedby="tooltip">
			{{localize 'FU.HealthAbbr'}}
		</label>
		<label class="fu-icon__container">
			<i class="resource-icon fu-icon--s {{pfuIconClass 'hp'}}"></i>
		</label>
	</div>
	<div class="resource-value-wrapper">
		<input class="resource-value-current bar-start" type="number"
			   name="system.resources.hp.value"
			   value="{{ system.resources.hp.value }}" data-dtype="Number" />
		<span class="resource-value-divider">/</span>
		<span class="resource-value-max">{{system.resources.hp.max}}</span>
	</div>
	<div class="bar-wrapper">
		<div class="bar bar-progress">

	<div class="bar-progress-bar {{#if actor.system.resources.hp.inCrisis}}bar-hp-crisis{{else}}bar-hp{{/if}}"
					 style="width: {{pfuPercentage system.resources.hp.value system.resources.hp.max}};"></div>
				<div class="center-line"
					 style="left:calc({{actor.system.resources.hp.crisisScore}} / {{actor.system.resources.hp.max}} * 100%);"></div>
				<div
				 style="left:calc({{actor.system.resources.hp.crisisScore}} / {{actor.system.resources.hp.max}} * 100%);"
				 class="crisis-restore resource-label-m resource-content"
				 data-tooltip="Crisis: {{system.resources.hp.crisisScore}}" aria-describedby="tooltip" data-action="crisisHP">
					<i class="fas fa-caret-right is-crisis crisisHP"></i>
					<i class="fas fa-caret-left is-crisis crisisHP"></i>
				</div>
			<span class="bar-value"></span>
		</div>
	</div>
</div>

