<a class="rest-button button-style minimal" data-tooltip="{{ localize 'FU.Reset' }}"
   aria-describedby="tooltip" data-action="rest" >
	{{#if (eq actor.type "character")}}
		<i class="fa fa-moon"></i>
	{{else}}
		<i class="fa fa-arrow-rotate-left"></i>
	{{/if}}
</a>

{{#if (eq actor.type "character")}}
	<div class="divider"></div>
	<!-- IP -->
	<div class="resource-container resource-content" data-tooltip="{{localize 'FU.InventoryPoints'}}<br>Current: {{
	system.resources.ip.value
	}}<br>Bonus: {{ system.resources.ip.bonus }} <br>Max: {{ system.resources.ip.max }}"
		 aria-describedby="tooltip">
		<div class="resource-label-wrapper">
			<label class="fu-icon__container resource-label-l" data-tooltip="{{localize 'FU.InventoryPoints'}}"
				   aria-describedby="tooltip">
				{{localize 'FU.InventoryAbbr'}}
			</label>
			<label class="fu-icon__container">
				<i class="resource-icon fu-icon--s {{pfuIconClass 'ip'}}"></i>
			</label>
		</div>
		<div class="resource-value-wrapper value-small">
			<input class="resource-value-current bar-start" type="number"
				   name="system.resources.ip.value"
				   value="{{ system.resources.ip.value }}" data-dtype="Number" />
