<div class="pfu-progress inline-desc flexrow flex-group-center resource-content" data-item-id="{{id}}">

	<div class="pfu-progress__segments__container">
		<div class="pfu-progress__segments" style="--segments: {{data.max}};" data-segments="{{data.max}}" data-index="{{index}}"
			 data-action="{{action}}"
			 data-id="{{id}}"
			 data-index="{{index}}"
			 data-update-amount="1"
			 data-alternate="true"
			 data-tooltip="{{localize 'FU.Progress'}}"
			 {{#if dataPath}}data-data-path="{{dataPath}}"{{/if}}>

			<div class="foreground"></div>

			{{#each arr as |obj key|}}
				<input class="pie slice{{obj.id}}" type="radio" value="{{obj.id}}" style="--index: {{obj.id}}" {{checked obj.checked}} />
				<div class="divider" style="--index: {{obj.id}}"></div>
			{{/each}}
		</div>
	</div>

	{{#if displayName}}
		{{#if compact}}
			<a data-action="openTrackMenu" data-id="{{id}}"
			   {{#if dataPath}}data-data-path="{{dataPath}}"{{/if}}
			   data-index="{{index}}">
				<span>{{localize displayName}}</span>
			</a>
		{{else}}
			<label>
				<span>{{localize displayName}}</span>
			</label>
		{{/if}}
	{{/if}}

	{{#unless compact}}
		{{> 'systems/projectfu/templates/common/progress/partials/progress-controls.hbs'}}
	{{/unless}}
</div>