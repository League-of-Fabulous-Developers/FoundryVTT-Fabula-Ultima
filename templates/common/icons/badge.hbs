<div class='fu-icon__container flex-group-center'
	 style="flex-direction: {{#if flexDir}}{{flexDir}}{{else}}column{{/if}}; {{#if gap includeZero=true}}gap: {{gap}};{{/if}}">
	<div class='fu-icon__badge'>
		<i class='fu-icon--{{size}} {{icon}}'></i>
		{{#if value includeZero=true}}
			<span class="fu-icon__badge-overlay">{{value}}</span>
		{{/if}}
	</div>
	{{#unless compact}}
		<span class="fu-icon__badge-label" {{#if fontSize}}style="font-size: var(--font-size-{{fontSize}});"{{/if}}>
			{{localize label}}
		</span>
	{{/unless}}
</div>