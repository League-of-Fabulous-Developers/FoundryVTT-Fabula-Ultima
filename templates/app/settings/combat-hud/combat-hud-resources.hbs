					</select>
				</div>
				<p class="notes">{{localize "FU.CombatHudTrackedResource4Hint"}}</p>
			</div>

			<h3>{{localize "FU.CombatHudTrackedNPCResources"}}</h3>
			<div class="form-group">
				<label for="optionCombatHudTrackedNPCResource1">{{localize "FU.CombatHudTrackedResource1"}}</label>
