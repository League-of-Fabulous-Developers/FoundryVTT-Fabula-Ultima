			{{#if hasCharacter}}
				<h3>{{localize "FU.CombatHudTrackedActorResources" name=userCharacter.name }}</h3>

				<div class="form-group">
					<label for="trackedActorResource1">{{localize "FU.CombatHudTrackedResource1"}}</label>
