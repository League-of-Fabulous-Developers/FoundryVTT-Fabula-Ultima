<section class="tab trackedResources {{tab.cssClass}} scrollable" data-group="primary" data-tab="trackedResources">
	<div class="settings-form desc">
		{{#if isGM}}
			<h3>{{localize "FU.CombatHudTrackedPCResources"}}</h3>
			<div class="form-group">
				<label for="optionCombatHudTrackedPCResource1">{{localize "FU.CombatHudTrackedResource1"}}</label>
				<div class="form-fields">
					<select name="optionCombatHudTrackedPCResource1" id="optionCombatHudTrackedPCResource1">
						{{selectOptions trackedResources selected=optionCombatHudTrackedPCResource1 localize=true}}
					</select>
				</div>
				<p class="notes">{{localize "FU.CombatHudTrackedResource1Hint"}}</p>
			</div>

			<div class="form-group">
				<label for="optionCombatHudTrackedPCResource2">{{localize "FU.CombatHudTrackedResource2"}}</label>
