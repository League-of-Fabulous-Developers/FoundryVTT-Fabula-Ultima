<div class="flexcol dialog-name resource-content">
	<div class="flexrow">
		<div class="dialog-image">
			<img src="{{img}}" data-tooltip="{{name}}" alt="{{name}}" />
		</div>
		<label class="resource-label">
			{{name}}
			<strong>【{{localize (lookup @root.FU.attributeAbbreviations system.attributes.primary)}} + {{localize (lookup @root.FU.attributeAbbreviations system.attributes.secondary)}}】 + {{system.accuracy}}</strong>
			 <strong>⬥ </strong>
			<strong>【{{#if hrZero}}{{localize "FU.HRZero"}}{{else}}{{localize "FU.HighRollAbbr"}}{{/if}} + {{system.damage.value}}】</strong> {{localize (lookup @root.FU.damageTypes system.damage.type)}}
		</label>
	</div>
	<div>
		<strong>{{localize (lookup @root.FU.weaponTypes system.type)}}</strong>
		<strong>{{localize 'FU.Versus'}}</strong>
		<strong>{{localize (lookup (lookup @root.FU.defenses system.defense) 'abbr')}}</strong>
	</div>
</div>