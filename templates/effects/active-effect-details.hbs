<section class="tab scrollable{{#if tab.active}} active{{/if}} active-effect-sheet" data-group="{{tab.group}}"
    data-tab="{{tab.id}}" style="color: rgba(17, 41, 41, 0.9)">

	<div class="desc">
		{{formGroup fields.tint value=source.tint rootId=rootId placeholder="#ffffff"}}
		{{formGroup fields.statuses value=source.statuses options=statuses rootId=rootId classes="statuses"}}
		{{#if isActorEffect}}
			{{formGroup fields.origin value=source.origin rootId=rootId disabled=true}}
		{{/if}}
		{{#if isItemEffect}}
			{{formGroup fields.transfer value=source.transfer rootId=rootId label=legacyTransfer.label
						hint=legacyTransfer.hint classes="active-effect-sheet"}}
		{{/if}}
		{{formGroup fields.disabled value=source.disabled rootId=rootId}}
	</div>
    {{formGroup fields.description value=source.description rootId=rootId classes="desc" name="description"}}
</section>