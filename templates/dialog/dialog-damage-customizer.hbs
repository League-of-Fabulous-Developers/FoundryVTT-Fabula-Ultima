<main class="">

	<fieldset class="title-fieldset resource-content flex-group-center flexrow desc">
		<legend class="resource-text-m">{{localize 'Targets'}}</legend>
		{{> 'systems/projectfu/templates/ui/partials/document-carousel.hbs' documents=targets}}
	</fieldset>

	<fieldset class="title-fieldset desc resource-content">
		<legend class="resource-label-full">
			<label class="resource-label-m">{{localize 'FU.Total'}}</label>
		</legend>
		<div id="total-damage" class="flex-group-center grid grid-5col flex3">
			<div>
				{{pfuBadge 'base' label='FU.Base' }}
				<label id="base" class="detail total">{{damage.modifiers.0.amount}}</label>
			</div>
			<div>
				{{pfuBadge 'hr' label='FU.HighRollAbbr' }}
				<label id="hr" class="detail total">{{damage.hr}}</label>
			</div>
			<div>
				{{pfuBadge 'mod' label='FU.Bonus' }}
				<label id="extra" class="detail">0</label>
			</div>
			<div>
				{{pfuBadge 'result' label='FU.Total' }}
				<label id="total" class="detail">{{damage.total}}</label>
			</div>
			<div class="fu-icon__container">
				<i id="damage-type-icon" class="fu-icon--m {{lookup FU.affIcon damage.type}}" style="flex: 0 1 auto;"></i>
			</div>
		</div>
	</fieldset>

	<fieldset class="title-fieldset desc resource-content">
		<div class="flexrow flex-group-center">
			<div class="form-group">
				<label for="extra-damage">
					<b>{{localize 'FU.Bonus'}}</b>
				</label>
				<input id="extra-damage" name="extra-damage" type="number" value="0" />
			</div>
			<div class="form-group">
				<label for="damage-type"><b>{{localize 'FU.Type'}}</b></label>
				<select id="damage-type" name="damage-type">
					{{selectOptions FU.damageTypes selected=damage.type localize=true}}
				</select>
			</div>
			<div class="form-group flex-auto">
				<label for="hr-zero"><b>{{localize 'FU.HRZeroStatus'}}</b></label>
				<input id="hr-zero" name="hr-zero" type="checkbox" />
			</div>
		</div>

	</fieldset>

	<fieldset class="title-fieldset desc resource-content">
		<legend class='resource-label-m' style="gap: 4px;">
				<span class="resource-label-sm">
					<a type="button"  id="check-all" class="resource-label-sm" data-tooltip="{{localize 'FU.IgnoreAll'}}" data-action="selectAll">
						<i class="icon fas fa-list-check"></i>
					</a>
				</span>
			<label>{{localize 'FU.IgnoreAffinities'}}</label>
			<span class="resource-label-sm">
					<a type="button" id="check-none" class="resource-label-sm" data-tooltip="{{localize 'FU.IgnoreNone'}}" data-action="deselectAll">
						<i class="icon fas fa-xmark-square"></i>
					</a>
				</span>
		</legend>
		<div class="grid-2col gap-2">
			<div class="form-group">
				<label for="ignore-vulnerable"><b>{{localize 'FU.IgnoreVulnerable'}}</b></label>
				<input id="ignore-vulnerable" class="ignore" name="ignore-vulnerable" type="checkbox" />
			</div>
			<div class="form-group">
				<label for="ignore-resistance"><b>{{localize 'FU.IgnoreResistances'}}</b></label>
				<input id="ignore-resistance" class="ignore" name="ignore-resistance" type="checkbox" />
			</div>
			<div class="form-group">
				<label for="ignore-immunities"><b>{{localize 'FU.IgnoreImmunities'}}</b></label>
				<input id="ignore-immunities" class="ignore" name="ignore-immunities" type="checkbox" />
			</div>
			<div class="form-group">
				<label for="ignore-absorption"><b>{{localize 'FU.IgnoreAbsorption'}}</b></label>
				<input id="ignore-absorption" class="ignore" name="ignore-absorption" type="checkbox" />
			</div>
		</div>
	</fieldset>
</main>
