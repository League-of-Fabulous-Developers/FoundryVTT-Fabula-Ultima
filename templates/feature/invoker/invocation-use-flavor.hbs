<header class="title-desc chat-header flexrow invocation-message">
    <a data-link draggable="true" data-uuid="{{uuid}}" 	   
	   data-type="Item" data-tooltip="{{name}}">
        <img class="item-img fu-icon--{{size}}" src="{{img}}" data-item-id="{{id}}" alt="{{name}}">
    </a>
	<i class="fu-icon--s {{icon}}"></i>
    <h2 style="flex-grow: 8; margin-left: 4px;">{{name}}</h2>

	{{> "systems/projectfu/templates/chat/partials/chat-message-toggle.hbs"}}
</header>
