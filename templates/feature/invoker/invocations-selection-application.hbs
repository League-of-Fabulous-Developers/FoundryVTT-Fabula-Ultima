<div class="pfu-wellspring {{wellspring.type}} flexcol gap-05 pfu-invocations-selection gap-8">
	<div class="grid-2col">
	{{#each wellsprings}}
		<a class="wellspring fu-icon__container"
		   data-action="selectWellspring"
		   data-type="{{wellspring.type}}"
		   data-tooltip="{{wellspring.name}}">
			<i class="fu-icon--l {{wellspring.icon}}"></i>
		</a>
	{{/each}}
	</div>
	<div class="grid grid-2col gap-8">
		{{#each invocations as |invocation|}}
			<div class="invocation-card"
			   data-action="useInvocation"
			   data-index="{{@index}}"
			   data-element="{{invocation.wellspring}}"
			   data-level="{{invocation.level}}"
			   data-tooltip="{{invocation.name}}">
				<div class="invocation-card__header">
					<i class="fu-icon--m {{pfuIconClass invocation.level}}"></i>
					<div class="invocation-card__name">{{invocation.name}}</div>
					<span class="invocation-card__label">{{localize invocation.label}}</span>
				</div>

				<div class="invocation-card__description">
					{{{invocation.description}}}
				</div>
			</div>
		{{/each}}
	</div>
</div>