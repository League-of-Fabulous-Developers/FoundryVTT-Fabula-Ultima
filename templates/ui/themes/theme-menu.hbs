<section class="pfu-layout__menu">
	<header>
		<div class="form-group">
			<label class="fu-form__property">
				{{localize "FU.Theme"}}
				<select name="theme" data-action="changeTheme">
					{{selectOptions themes selected=current blank="FU.Custom" valueAttr="value" labelAttr="label"
					                localize=true}}
				</select>
			</label>
		</div>
		<div class="form-group">
			<label class="fu-form__property">
				{{localize "FU.ThemeFoundrySetting"}}
				<input type="checkbox" name="themeFoundry" {{checked themeFoundry}}>
			</label>
		</div>
		<div class="form-group buttons">
			<button type="button" data-action="importTheme" name="import">
				<i class="fas fa-file-import"></i>{{localize "FU.Import"}}
			</button>
			<button type="button" data-action="exportTheme" name="export">
				<i class="fas fa-file-export"></i>{{localize "FU.Export"}}
			</button>
		</div>
	</header>
	<main>
		<div class="desc fu-form__grid">
			{{#each fields}}
				{{#if (eq this.type "multiline-text")}}
					<label class="fu-form__property" data-tooltip="{{localize hint}}">
						<span>{{localize label}}</span>
						<span class="flexrow">
						<textarea name="{{@key}}" rows="5">{{lookup ../current @key}}</textarea>
						</span>
					</label>
				{{else}}
					<label class="fu-form__property" data-tooltip="{{localize hint}}">
						<span>{{localize label}}</span>
						{{#if (eq this.type "color")}}
							<span class="flexrow">
							<input type="color" name="{{@key}}" value="{{lookup ../current @key}}">
							</span>
						{{else if (eq this.type "image")}}
							<span class="flexrow">
							<input type="text" name="{{@key}}" value="{{lookup ../current @key}}">
							<button
							 type="button"
							 data-action="filePicker"
							 data-target="{{@key}}"
							 data-type="image"
							 title="Browse Files">
								<i class="fas fa-file-import"></i>
							</button>
							</span>
						{{else}}
							<span class="flexrow">
							<input type="text" name="{{@key}}" value="{{lookup ../current @key}}">
							</span>
						{{/if}}
					</label>
				{{/if}}
			{{/each}}
		</div>
	</main>
	<footer>
		<div class="flexrow flex-group-center">
			<button type="button" name="apply" data-action="applyTheme">
				<i class="fas fa-palette"></i>{{localize "FU.Preview"}}
			</button>
			<button type="submit" name="submit" data-action="saveTheme">
				<i class="fas fa-floppy-disk"></i>{{localize "FU.Save"}}
			</button>
			<button type="reset" name="reset">
				<i class="fas fa-undo"></i>{{localize "FU.Reset"}}
			</button>
		</div>
	</footer>
</section>