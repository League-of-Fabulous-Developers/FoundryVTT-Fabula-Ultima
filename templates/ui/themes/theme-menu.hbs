<section class="fu-layout__menu">
	<header>
		<div class="form-group">
			<label for="theme" class="fu-form__property">
				{{localize "FU.Theme"}}
				<select name="theme">
					<option value="">{{localize "FU.Custom"}}</option>
					{{#each themes}}
						<option value="{{@key}}">{{localize (concat "FU.THEMES." @key)}}</option>
					{{/each}}
				</select>
			</label>
		</div>
		<div class="form-group buttons">
			<button type="button" name="import">
				<i class="fas fa-file-import"></i>{{localize "FU.Import"}}
			</button>
			<button type="button" name="export">
				<i class="fas fa-file-export"></i>{{localize "FU.Export"}}
			</button>
		</div>
		<hr>
	</header>
	<main class="background">
		{{#each settings}}
			{{#if (eq this.type "multiline-text")}}
				<label class="fu-form__property" data-tooltip="{{localize hint}}">
					<span>{{localize label}}</span>
					<textarea name="{{@key}}" rows="5">{{lookup ../current @key}}</textarea>
				</label>
			{{else}}
				<label class="fu-form__property" data-tooltip="{{localize hint}}">
					<span>{{localize label}}</span>
					<input type="text" name="{{@key}}" {{#if (eq this.type "color")}}data-color-picker="{alphaChannel: true, format: 'hexa', required: false}"{{/if}} value="{{lookup ../current @key}}">
					{{#if (eq this.type "image")}}{{filePicker target=@key type="image"}}{{/if}}
				</label>
			{{/if}}
		{{/each}}
	</main>
	<footer>
		<div class="flexrow flex-group-center">
			<button type="submit" name="apply">
				<i class="fas fa-palette"></i>{{localize "FU.Apply"}}
			</button>
			<button type="submit" name="submit">
				<i class="fas fa-floppy-disk"></i>{{localize "FU.Save"}}
			</button>
			<button type="reset" name="reset">
				<i class="fas fa-undo"></i>{{localize "FU.Reset"}}
			</button>
		</div>
	</footer>
</section>