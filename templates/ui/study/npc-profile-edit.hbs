<div class="npc-profile">

	<div class="flexrow flex-group-center">
		{{pfuActorProfile actor}}
	</div>

	<fieldset class="section-container title-fieldset desc resource-content">
		<legend class="resource-label-m">{{localize 'FU.Study'}}</legend>
		<div class="">
			{{pfuBadge 'result' label='FU.Total' value=existing.study size='l' }}
			<div class="study-total">
				<label for="study">
					<input id="study" type="range" data-tooltip="{{existing.study}}" name="study" value="{{existing.study}}" min="0" max="{{studyDifficulties.[2]}}" step="1" list="studyDifficulties">
				</label>
				<datalist id="studyDifficulties">
					<option value="0" label="0"></option>
					{{#each studyDifficulties}}
						<option value="{{this}}" label="{{this}}"></option>
					{{/each}}
				</datalist>
				<div class="markers">
					<span class="marker" style="position: absolute; left: 0">0</span>
					{{#with studyDifficulties.[2] as | max |}}
						{{#each @root.studyDifficulties}}
							<span class="marker" style="position: absolute; left: calc((100% - {{#if (gte this 10)}}15px{{else}}9px{{/if}}) * ({{this}}/{{max}}))">{{this}}</span>
						{{/each}}
					{{/with}}
				</div>
			</div>
		</div>
	</fieldset>

	<div class="flexrow flex-group-center gap-8">
		<fieldset class="section-container title-fieldset desc resource-content">
			<legend class="resource-label-m">
				{{localize 'FU.Affinities'}}
			</legend>
			<div class="grid-2col align-left">
				{{#each affinities}}
					<label>
						<input type="checkbox"
							   name="affinities.{{this}}" {{#if (lookup ../existing.revealed.affinities this)}}checked{{/if}} />
						{{localize (lookup @root.FU.damageTypes this)}} ({{localize (lookup ../affinityMap this)}})
					</label>
				{{/each}}
			</div>
		</fieldset>

		{{#if pressurePoints}}
			<fieldset class="section-container title-fieldset desc resource-content">
				<legend class="resource-label-m">
					{{localize 'FU.PressurePoints'}}
				</legend>
				<div class="grid-2col align-left">
					{{#each weaponCategories}}
						<label>
							<input type="checkbox"
								   name="pressurePoints.{{@key}}" {{#if (lookup ../existing.revealed.pressurePoints @key)}}checked{{/if}} />
							{{localize this}}
							{{#if (lookup ../pressurePoints @key)}}
								({{localize 'FU.PressurePointAbbr'}})
							{{else}}
								(-)
							{{/if}}
						</label>
					{{/each}}
				</div>
			</fieldset>
		{{/if}}
	</div>

	{{#if traits}}
		<fieldset class="section-container title-fieldset desc resource-content">
			<legend class="resource-label-m">
				{{localize 'FU.Traits'}}
			</legend>
			<div class="grid-2col align-left">
				{{#each traits}}
					<label>
						<input type="checkbox"
							   name="traits.{{this}}"
							   {{#if (pfuCollectionContains ../existing.revealed.traits this)}}checked{{/if}} />
						{{this}}
					</label>
				{{/each}}
			</div>
		</fieldset>
	{{/if}}

	{{#if statusImmunities}}
		<fieldset class="section-container title-fieldset desc resource-content">
			<legend class="resource-label-m">
				{{localize "FU.StatusEffectImmunity"}}
			</legend>
			<div class="grid-2col align-left">
				{{#each statusImmunities}}
					<label>
						<input type="checkbox"
						       name="statusImmunities.{{this}}"
						       {{#if (lookup ../existing.revealed.statusImmunities this)}}checked{{/if}} />
						{{this}}
					</label>
				{{/each}}
			</div>
		</fieldset>
	{{/if}}

	{{#if actor.itemTypes.miscAbility}}
		<fieldset class="section-container title-fieldset desc resource-content">
			<legend class="resource-label-m">
				{{localize "FU.Actions"}}
			</legend>
			<div class="flexcol">
				{{#each actor.itemTypes.miscAbility}}
					<label>
						<input type="checkbox" name="abilities.{{id}}"
						       {{#if (lookup ../existing.revealed.abilities id)}}checked{{/if}} />
						{{name}}
					</label>
				{{/each}}
			</div>
		</fieldset>
	{{/if}}

	{{#if actor.itemTypes.rule}}
		<fieldset class="section-container title-fieldset desc resource-content">
			<legend class="resource-label-m">
				{{localize 'FU.SpecialRules'}}
			</legend>
			<div class="flexcol">
				{{#each actor.itemTypes.rule}}
					<label>
						<input type="checkbox" name="rules.{{id}}"
						       {{#if (lookup ../existing.revealed.rules id)}}checked{{/if}} />
						{{name}}
					</label>
				{{/each}}
			</div>
		</fieldset>
	{{/if}}
</div>