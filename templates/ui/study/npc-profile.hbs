<div class="npc-profile sheet-body">
	<div class="top">
		<!-- Left content here -->
		<div class="left-column">
			<a data-action="revealActor">
				<img class="avatar" src="{{ img }}" />
			</a>
		</div>
		<!-- Right content here -->
		<div class="right-column">
			<div class="flexrow flex-group-center">
				<span class="label name">{{name}}</span>
				<span class="pfu-badge__level large" data-tooltip="{{localize 'FU.LevelAbbr'}}">{{level}}</span>
			</div>

			{{#unless revealStats}}
				<fieldset class="section-container title-fieldset desc resource-content">
					<span class="label centered-message">
						{{localize 'FU.AdversaryNotStudied'}}
					</span>
				</fieldset>
			{{/unless}}
			{{#if revealStats}}
				<fieldset class="section-container title-fieldset desc resource-content">
					<legend class="resource-label-m">
						{{localize 'FU.Stats'}}
					</legend>
					{{#if basic}}
					<div class="resource-label-l resource-content flexrow flex-group-center">
						<div class="pfu-badge" data-tooltip="{{localize localizedSpecies}}">
							<i class="fua fu-{{species}}"></i>
						</div>
						<span class="diamond-symbol">⬥</span>
						<label class="flexcol" data-tooltip="{{localize 'FU.HealthPoints'}}">
							<i class="fas fa-heart"></i>
							{{hp}}
						</label>
						<span class="diamond-symbol">⬥</span>
						<label class="flexcol" data-tooltip="{{localize 'FU.MindPoints'}}">
							<i class="fas fa-hat-wizard"></i>
							{{mp}}
						</label>
					</div>
					{{/if}}

					{{#if complete}}
						{{>"systems/projectfu/templates/actor/partials/actor-attributes-readonly.hbs"}}

						<div class="flexrow flex-group-center">
							{{>"systems/projectfu/templates/actor/partials/actor-derived-stats.hbs"}}
						</div>

						{{#if system.traits.value}}
							<li class="flexrow gap-5 flex-group-center desc-header resource-content">
								<label class="flexshrink resource-label-l">Traits</label>
								<input type="text" name="system.traits.value" value="{{system.traits.value}}" placeholder="Traits" data-dtype="String" readonly>
							</li>
						{{/if}}
					{{else}}
						{{#if revealed.traits}}
							<li class="flexrow gap-5 flex-group-center desc-header resource-content ">
								<label class="flexshrink resource-label-l">Traits</label>
								<input type="text" name="revealed.traits" value="{{revealed.traits}}" placeholder="Traits" data-dtype="String" readonly>
							</li>
						{{/if}}
					{{/if}}
				</fieldset>
			{{/if}}
		</div>
	</div>
	{{#if complete}}
		<fieldset class="section-container title-fieldset desc resource-content">
			<legend class="resource-label-m">
				{{localize 'FU.Affinities'}}
			</legend>
			{{> "systems/projectfu/templates/actor/partials/actor-affinities.hbs" actor=actor}}
		</fieldset>
	{{/if}}

	{{#if statusImmunities}}
		<fieldset class="section-container title-fieldset desc resource-content">
			<legend class="resource-label-m">
				{{localize "FU.StatusEffectImmunity"}}
			</legend>
			<div class="grid grid-3col align-left">
				{{#each statusImmunities}}
					<div class="resource-content flex-group-center">
						<label class="fu-icon__container immune">
							<i class="fu-icon--s {{pfuIconClass this}}"></i>
							<strong>{{localize (lookup @root.statusEffects this)}}</strong>
						</label>
					</div>
				{{/each}}
			</div>
		</fieldset>
	{{/if}}

	{{#if revealPressurePoints}}
		<fieldset class="section-container title-fieldset desc resource-content">
			<legend class="resource-label-m">
				{{localize 'FU.PressurePoints'}}
			</legend>
			<div class="grid grid-10col">
				{{#each weaponCategories}}
					<div class="resource-content flex-group-center">
						<label class="fu-icon__container"
							   data-tooltip="{{localize this}} <br> {{#if (lookup ../pressurePoints @key)}}{{localize 'FU.PressurePoint'}}{{/if}}">
							<i class="fu-icon--s {{pfuIconClass @key}} {{#unless (lookup ../pressurePoints @key)}}fu-form__disabled{{/unless}}"></i>
							{{#if (lookup ../pressurePoints @key)}}
								{{#if (pfuCollectionContains @key ../actor.system.pressurePoints.entries)}}
									<span class="resource-label-l">{{localize 'FU.PressurePointAbbr'}}</span>
								{{/if}}
							{{/if}}
						</label>
					</div>
				{{/each}}
			</div>
		</fieldset>
	{{/if}}

	<!-- Bottom content here -->
	{{#if (or detailed abilitiesTable rulesTable)}}
		<div class="bottom-row">
			<fieldset class="section-container title-fieldset desc resource-content">
				<legend class="resource-label-m">
					{{localize 'FU.Actions'}}
				</legend>

				<section class="desc fu-scrollable" style="max-height: 400px;">
					{{#if detailed}}
						{{{basicAttacksTable}}}
						{{#if actor.system.useEquipment.value}}
							{{{weaponsTable}}}
						{{/if}}
						{{{spellsTable}}}
					{{/if}}
					{{{abilitiesTable}}}
					{{{rulesTable}}}
				</section>
			</fieldset>
		</div>
	{{/if}}
</div>
