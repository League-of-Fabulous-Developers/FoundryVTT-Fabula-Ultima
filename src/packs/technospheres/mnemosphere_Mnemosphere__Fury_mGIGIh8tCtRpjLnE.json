      {
        "name": "Indomitable Spirit",
        "type": "skill",
        "_id": "Z8mc8sxxCg4e0Cxd",
        "img": "systems/projectfu/styles/static/compendium/classes/fury/fury_indomitable_spirit.png",
        "system": {
          "summary": {
            "value": ""
          },
          "description": "<p>When you spend one or more Fabula Points, you get an additional benefit — choose one option:</p><ul><li><p>You recover <strong>【SL × 5】</strong> Hit Points.</p></li><li><p>You recover <strong>【SL × 5】</strong> Mind Points.</p></li><li><p>You recover from a single status effect of your choice.</p></li></ul><hr /><p><strong>You Recover:</strong> @GAIN[5*$sl hp]{SL × 5 HP} or @GAIN[5*$sl mp]{SL × 5 MP}</p>",
