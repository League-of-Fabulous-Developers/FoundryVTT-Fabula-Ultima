      {
        "name": "Follow My Lead",
        "type": "skill",
        "img": "systems/projectfu/styles/static/compendium/classes/dancer/dancer_follow_my_lead.png",
        "system": {
          "summary": {
            "value": ""
          },
          "description": "<p>When you perform a <strong>dance</strong> with a <strong>duration</strong> of \"Until the start of your next turn\", you may spend 10 Mind Points. If you do, choose one ally you can see towards whom you have a Bond of <strong>affection</strong>: apply the benefits of the <strong>dance</strong> to that ally as well as yourself (the benefits still last until the start of <strong>your</strong> next turn).</p>",
